# Copy to .env and fill in. Never commit .env.

# OpenRouter API key — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# MongoDB Atlas connection string (database "CruzAidDB")
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority

# Twilio auth token — verifies incoming /sms requests really came from Twilio.
# Find it in the Twilio Console. Unset = signature check skipped (dev only).
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Optional: Redis URL to share rate limits across gunicorn workers.
# Leave unset for local single-worker dev (falls back to in-memory).
# RATELIMIT_STORAGE_URI=redis://localhost:6379
